FROM python:3.11-alpine

# System-Abhängigkeiten installieren
RUN apk add --no-cache \
    bash \
    tzdata

# Arbeitsverzeichnis definieren
WORKDIR /app

# Python-Abhängigkeiten installieren
# Zuerst die requirements-Datei kopieren und installieren, um den Docker-Layer-Cache zu nutzen
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Den Rest des Anwendungscodes kopieren
COPY heis-o-mat.py .
COPY start-downloads.sh .

# Skripte ausführbar machen
RUN chmod +x start-downloads.sh

# Download-Verzeichnis erstellen
RUN mkdir -p /downloads

# Standard-Umgebungsvariablen
ENV TZ=Europe/Berlin \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    DOWNLOAD_DIR=/downloads \
    RUN_ON_STARTUP=true \
    CRON_SCHEDULE="0 10 * * 6"

# Entrypoint-Skript kopieren
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]